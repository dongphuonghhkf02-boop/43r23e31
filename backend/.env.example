# DM Auto / BIBI Cars — backend environment template.
# Copy to `backend/.env` and fill in real values. Never commit the real .env.

# MongoDB connection (e.g. mongodb://localhost:27017 or a managed Atlas URI)
MONGO_URL="mongodb://localhost:27017"

# Database name used by the FastAPI app
DB_NAME="bibi_cars"

# Comma-separated origins allowed by CORS. Use "*" for local dev.
CORS_ORIGINS="*"

# Optional: explicitly enable the parser/ingestion pipeline.
# When unset, parsers are FROZEN (admin-curated catalog only).
# PARSERS_ENABLED=1

# Optional: Emergent universal LLM key for OpenAI / Anthropic / Gemini.
# EMERGENT_LLM_KEY=
