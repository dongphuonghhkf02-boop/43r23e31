# DM Auto / BIBI Cars — frontend environment template.
# Copy to `frontend/.env` and fill in real values. Never commit the real .env.

# Public URL of the FastAPI backend. The frontend prepends `/api` to every
# call so this MUST point at the host that serves the backend routes.
REACT_APP_BACKEND_URL=http://localhost:8001

# Webpack dev-server socket port (CRA inside the Emergent preview proxy).
WDS_SOCKET_PORT=443

# Disable the noisy webpack health-check ping in production builds.
ENABLE_HEALTH_CHECK=false
